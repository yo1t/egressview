# Normalize line endings on checkout
* text=auto

# Force LF for source files
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.sql   text eol=lf

# Binary files — no line-ending conversion
*.db     binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.pem    binary
